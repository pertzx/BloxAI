local function setupHockeyGame()
    -- Criar a arena de hockey se não existir
    local arena = Instance.new("Model", workspace)
    arena.Name = "HockeyArena"
    
    -- Criar o piso da arena
    local base = Instance.new("Part", arena)
    base.Size = Vector3.new(100, 1, 50)
    base.Position = Vector3.new(0, 0, 0)
    base.Anchored = true
    base.Material = Enum.Material.Plastic
    base.BrickColor = BrickColor.new("Bright blue")
    
    -- Criar as balizas
    local goalLeft = Instance.new("Part", arena)
    goalLeft.Size = Vector3.new(1, 3, 5)
    goalLeft.Position = Vector3.new(-50, 1.5, 0)
    goalLeft.Anchored = true
    goalLeft.BrickColor = BrickColor.new("Bright red")
    
    local goalRight = Instance.new("Part", arena)
    goalRight.Size = Vector3.new(1, 3, 5)
    goalRight.Position = Vector3.new(50, 1.5, 0)
    goalRight.Anchored = true
    goalRight.BrickColor = BrickColor.new("Bright red")
    
    -- Criar o disco de hockey
    local puck = Instance.new("Part", arena)
    puck.Size = Vector3.new(1, 0.5, 1)
    puck.Position = Vector3.new(0, 1, 0)
    puck.Anchored = false
    puck.BrickColor = BrickColor.new("Black")
    
    -- Configurar a física do disco
    puck.CanCollide = true
    puck.Material = Enum.Material.SmoothPlastic
    
    -- Adicionar um script para movimentar o disco
    local puckScript = Instance.new("Script", puck)
    puckScript.Source = [=[
        local puck = script.Parent
        local function onTouch(hit)
            if hit:IsA("Player") then
                puck.Velocity = (hit.Position - puck.Position).unit * 50
            end
        end
        puck.Touched:Connect(onTouch)
    ]=]
end

setupHockeyGame()

