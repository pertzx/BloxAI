<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Blox AI - Login">
    <title>Login | Blox AI</title>
    
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>
<body class="auth-body">
    <div class="auth-container">
        <!-- Background Animation -->
        <div class="auth-bg">
            <div class="bg-gradient-1"></div>
            <div class="bg-gradient-2"></div>
            <div class="bg-grid"></div>
        </div>
        
        <!-- Auth Card -->
        <div class="auth-card" id="loginCard">
            <!-- Logo -->
            <div class="auth-logo">
                <div class="logo-icon">
                    <i class="fas fa-cube"></i>
                </div>
                <h1 class="logo-text">Blox <span class="gradient-text">AI</span></h1>
            </div>
            
            <!-- Header -->
            <div class="auth-header">
                <h2>Bem-vindo de volta</h2>
                <p>Faça login para continuar construindo</p>
            </div>
            
            <!-- Tabs -->
            <div class="auth-tabs">
                <button class="auth-tab active">Login</button>
                <a href="/register" class="auth-tab">Cadastro</a>
            </div>
            
            <!-- Form -->
            <form class="auth-form" id="loginForm" novalidate>
                <!-- Email -->
                <div class="form-group">
                    <label for="email">
                        <i class="fas fa-envelope"></i>
                        Email
                    </label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        required 
                        placeholder="seu@email.com"
                        autocomplete="email"
                    >
                    <span class="form-error" id="emailError"></span>
                </div>
                
                <!-- Password -->
                <div class="form-group">
                    <label for="password">
                        <i class="fas fa-lock"></i>
                        Senha
                    </label>
                    <div class="password-input">
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            required 
                            placeholder="Sua senha"
                            autocomplete="current-password"
                        >
                        <button type="button" class="toggle-password" data-target="password">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span class="form-error" id="passwordError"></span>
                </div>
                
                <!-- Remember & Forgot -->
                <div class="form-row-between">
                    <label class="checkbox-label">
                        <input type="checkbox" id="remember" name="remember">
                        <span class="checkbox-custom"></span>
                        <span class="checkbox-text">Lembrar de mim</span>
                    </label>
                    <a href="/forgot-password" class="forgot-link">Esqueceu a senha?</a>
                </div>
                
                <!-- Submit -->
                <button type="submit" class="btn btn-primary btn-block btn-lg" id="submitBtn">
                    <span class="btn-text">Entrar</span>
                    <span class="btn-loader" style="display:none;">
                        <i class="fas fa-spinner fa-spin"></i>
                    </span>
                </button>
            </form>
            
            <!-- Divider -->
            <div class="auth-divider">
                <span>ou entre com</span>
            </div>
            
            <!-- Social Login -->
            <div class="social-login">
                <button class="social-btn" data-provider="google">
                    <i class="fab fa-google"></i>
                    Google
                </button>
                <button class="social-btn" data-provider="github">
                    <i class="fab fa-github"></i>
                    GitHub
                </button>
                <button class="social-btn" data-provider="discord">
                    <i class="fab fa-discord"></i>
                    Discord
                </button>
            </div>
            
            <!-- Register Link -->
            <div class="auth-footer">
                <p>Não tem uma conta? <a href="/register">Crie agora</a></p>
            </div>
        </div>
        
        <!-- Info Panel -->
        <div class="auth-info">
            <div class="info-content">
                <h2>Seu dev sênior de Roblox<br>que <span class="gradient-text">nunca dorme</span></h2>
                <p>Construa jogos incríveis com o poder da inteligência artificial avançada.</p>
                
                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-number">10K+</div>
                        <div class="stat-label">Devs ativos</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">50K+</div>
                        <div class="stat-label">Projetos</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">1M+</div>
                        <div class="stat-label">Scripts gerados</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">99.9%</div>
                        <div class="stat-label">Uptime</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Toast Container -->
    <div id="toastContainer" class="toast-container"></div>
    
    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/main.js"></script>
    <script>
        // Initialize login page
        document.addEventListener('DOMContentLoaded', () => {
            initLoginPage();
        });
    </script>
</body>
</html>
