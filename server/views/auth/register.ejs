<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Blox AI - Crie sua conta">
    <title>Cadastro | Blox AI</title>
    
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>
<body class="auth-body">
    <div class="auth-container">
        <!-- Background Animation -->
        <div class="auth-bg">
            <div class="bg-gradient-1"></div>
            <div class="bg-gradient-2"></div>
            <div class="bg-grid"></div>
        </div>
        
        <!-- Auth Card -->
        <div class="auth-card" id="registerCard">
            <!-- Logo -->
            <div class="auth-logo">
                <div class="logo-icon">
                    <i class="fas fa-cube"></i>
                </div>
                <h1 class="logo-text">Blox <span class="gradient-text">AI</span></h1>
            </div>
            
            <!-- Header -->
            <div class="auth-header">
                <h2>Crie sua conta</h2>
                <p>Comece a usar o agente de IA mais avançado para Roblox</p>
            </div>
            
            <!-- Tabs -->
            <div class="auth-tabs">
                <a href="/login" class="auth-tab">Login</a>
                <button class="auth-tab active">Cadastro</button>
            </div>
            
            <!-- Form -->
            <form class="auth-form" id="registerForm" novalidate>
                <!-- Name Row -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="firstName">
                            <i class="fas fa-user"></i>
                            Nome
                        </label>
                        <input 
                            type="text" 
                            id="firstName" 
                            name="firstName" 
                            required 
                            minlength="2"
                            placeholder="Seu nome"
                            autocomplete="given-name"
                        >
                        <span class="form-error" id="firstNameError"></span>
                    </div>
                    
                    <div class="form-group">
                        <label for="lastName">
                            <i class="fas fa-user"></i>
                            Sobrenome
                        </label>
                        <input 
                            type="text" 
                            id="lastName" 
                            name="lastName" 
                            required 
                            minlength="2"
                            placeholder="Seu sobrenome"
                            autocomplete="family-name"
                        >
                        <span class="form-error" id="lastNameError"></span>
                    </div>
                </div>
                
                <!-- Email -->
                <div class="form-group">
                    <label for="email">
                        <i class="fas fa-envelope"></i>
                        Email
                    </label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        required 
                        placeholder="seu@email.com"
                        autocomplete="email"
                    >
                    <span class="form-error" id="emailError"></span>
                </div>
                
                <!-- Password -->
                <div class="form-group">
                    <label for="password">
                        <i class="fas fa-lock"></i>
                        Senha
                    </label>
                    <div class="password-input">
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            required 
                            minlength="8"
                            placeholder="Mínimo 8 caracteres"
                            autocomplete="new-password"
                        >
                        <button type="button" class="toggle-password" data-target="password">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div class="password-strength" id="passwordStrength">
                        <div class="strength-bar">
                            <div class="strength-fill" id="strengthFill"></div>
                        </div>
                        <span class="strength-text" id="strengthText">Digite uma senha</span>
                    </div>
                    <span class="form-error" id="passwordError"></span>
                </div>
                
                <!-- Confirm Password -->
                <div class="form-group">
                    <label for="confirmPassword">
                        <i class="fas fa-lock"></i>
                        Confirmar Senha
                    </label>
                    <div class="password-input">
                        <input 
                            type="password" 
                            id="confirmPassword" 
                            name="confirmPassword" 
                            required 
                            placeholder="Digite a senha novamente"
                            autocomplete="new-password"
                        >
                        <button type="button" class="toggle-password" data-target="confirmPassword">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span class="form-error" id="confirmPasswordError"></span>
                </div>
                
                <!-- Terms -->
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="terms" name="terms" required>
                        <span class="checkbox-custom"></span>
                        <span class="checkbox-text">
                            Concordo com os <a href="/terms" target="_blank">Termos de Uso</a> 
                            e <a href="/privacy" target="_blank">Política de Privacidade</a>
                        </span>
                    </label>
                </div>
                
                <!-- Newsletter -->
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="newsletter" name="newsletter">
                        <span class="checkbox-custom"></span>
                        <span class="checkbox-text">
                            Quero receber atualizações sobre novos recursos
                        </span>
                    </label>
                </div>
                
                <!-- Submit -->
                <button type="submit" class="btn btn-primary btn-block btn-lg" id="submitBtn">
                    <span class="btn-text">Criar Conta</span>
                    <span class="btn-loader" style="display:none;">
                        <i class="fas fa-spinner fa-spin"></i>
                    </span>
                </button>
            </form>
            
            <!-- Divider -->
            <div class="auth-divider">
                <span>ou cadastre-se com</span>
            </div>
            
            <!-- Social Login -->
            <div class="social-login">
                <button class="social-btn" data-provider="google">
                    <i class="fab fa-google"></i>
                    Google
                </button>
                <button class="social-btn" data-provider="github">
                    <i class="fab fa-github"></i>
                    GitHub
                </button>
                <button class="social-btn" data-provider="discord">
                    <i class="fab fa-discord"></i>
                    Discord
                </button>
            </div>
            
            <!-- Login Link -->
            <div class="auth-footer">
                <p>Já tem uma conta? <a href="/login">Faça login</a></p>
            </div>
        </div>
        
        <!-- Info Panel -->
        <div class="auth-info">
            <div class="info-content">
                <h2>Junte-se a +10.000 desenvolvedores</h2>
                <p>Crie sistemas complexos, UIs incríveis e mecânicas de jogo em minutos com o poder da IA.</p>
                
                <div class="features-list">
                    <div class="feature-item">
                        <i class="fas fa-rocket"></i>
                        <div>
                            <h4>10x mais rápido</h4>
                            <p>Desenvolva em minutos o que levaria horas</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-brain"></i>
                        <div>
                            <h4>IA Multi-Provider</h4>
                            <p>GPT-4o, Gemini, Kimi e APIs customizadas</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-shield-alt"></i>
                        <div>
                            <h4>100% Seguro</h4>
                            <p>Seus dados criptografados e protegidos</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-infinity"></i>
                        <div>
                            <h4>Uso Ilimitado</h4>
                            <p>Sem limites de projetos ou requisições</p>
                        </div>
                    </div>
                </div>
                
                <div class="testimonial">
                    <p>"O Blox AI transformou meu workflow. Agora consigo criar jogos inteiros em uma tarde."</p>
                    <div class="testimonial-author">
                        <div class="author-avatar">JM</div>
                        <div>
                            <strong>João Mendes</strong>
                            <span>Dev Roblox há 3 anos</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Toast Container -->
    <div id="toastContainer" class="toast-container"></div>
    
    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/main.js"></script>
    <script>
        // Initialize register page
        document.addEventListener('DOMContentLoaded', () => {
            initRegisterPage();
        });
    </script>
</body>
</html>
