# =============================================================================
#  BLOX AI — Backend  |  Variáveis de Ambiente
#  Copie este arquivo: cp .env.example .env
#  Nunca faça commit do .env real — ele contém segredos.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------

# Porta onde o backend escuta.
PORT=5000

# Ambiente. Em produção, JWT_SECRET vazio causa crash intencional.
NODE_ENV=development


# -----------------------------------------------------------------------------
# SEGURANÇA — JWT
# -----------------------------------------------------------------------------

# Segredo para assinar todos os tokens da plataforma.
# Gere um valor seguro no terminal:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# OBRIGATÓRIO em produção.
JWT_SECRET=coloque_aqui_64_caracteres_aleatorios


# -----------------------------------------------------------------------------
# BANCO DE DADOS — MongoDB
# -----------------------------------------------------------------------------

# ► Desenvolvimento local
#   Instale MongoDB Community Edition: https://www.mongodb.com/try/download/community
#   Inicie com: mongod --dbpath ./data
MONGODB_URI=mongodb://localhost:27017/bloxai

# ► Produção — MongoDB Atlas (recomendado, gratuito até 512 MB)
#   1. Crie conta em https://cloud.mongodb.com
#   2. Crie um cluster Free Tier (M0)
#   3. Database Access → Add Database User (anote usuário e senha)
#   4. Network Access → Add IP Address → 0.0.0.0/0 (ou IP fixo do servidor)
#   5. Connect → Drivers → copie a URI e substitua <password>
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bloxai?retryWrites=true&w=majority


# -----------------------------------------------------------------------------
# FILA ASSÍNCRONA — Redis  (modo Think)
# -----------------------------------------------------------------------------

# ► Desenvolvimento local
#   Via Docker: docker run -d -p 6379:6379 redis:alpine
#   Ou instale: https://redis.io/docs/install/
REDIS_URL=redis://localhost:6379

# ► Produção — Upstash Redis (grátis até 10 000 req/dia, sem servidor)
#   1. Crie conta em https://upstash.com
#   2. Databases → Create Database → Regional
#   3. Copie a "Redis URL" (começa com rediss://)
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379


# -----------------------------------------------------------------------------
# AUTENTICAÇÃO — Roblox OAuth 2.0
# -----------------------------------------------------------------------------

# Como criar seu app OAuth na Roblox:
#   1. Acesse https://create.roblox.com/dashboard/credentials
#   2. Clique em "Create OAuth App"
#   3. Preencha nome e descrição
#   4. Em "Redirect URLs" adicione o valor de ROBLOX_REDIRECT_URI abaixo
#   5. Em "Permissions" marque: openid  profile
#   6. Salve e copie o Client ID
#   7. Em "Client Secrets" clique em "Add Secret" e copie o valor gerado
ROBLOX_OAUTH_CLIENT_ID=2173064084433819711
ROBLOX_OAUTH_CLIENT_SECRET=RBX-ViyVWq3xn0W7S3WzowHshSk6-VDn9GYIFThxsYbHW8sSPi-GCKuVnwosMeEitmuv

# URL de callback que a Roblox chama após o usuário autorizar.
# DEVE ser idêntica à URL cadastrada no passo 4 acima.
ROBLOX_REDIRECT_URI=http://localhost:5000/api/auth/roblox/callback
# Em produção: https://api.seudominio.com/api/auth/roblox/callback

# URL do frontend. O backend redireciona aqui com o token JWT.
FRONTEND_URL=http://localhost:5173
# Em produção: https://seudominio.com

# IDs Roblox (numéricos) que recebem role "admin" automaticamente no 1º login.
# Como descobrir seu ID Roblox:
#   Abra https://www.roblox.com/users/<seu_username>/profile
#   O número na URL é seu ID. Ex: /users/156/profile → ID é 156
# Separe múltiplos com vírgula: 156,789,321
ADMIN_ROBLOX_IDS=2660079327


# -----------------------------------------------------------------------------
# E-MAIL TRANSACIONAL — SMTP (Nodemailer)
# -----------------------------------------------------------------------------

# Qualquer servidor SMTP funciona: Gmail, Outlook, Zoho, Brevo, Mailtrap...
# Se SMTP_HOST estiver vazio, os e-mails são apenas printados no console (dev).
#
# ► Gmail (grátis, 500/dia)
#   1. Ative 2FA em https://myaccount.google.com/security
#   2. Gere uma "Senha de app" em https://myaccount.google.com/apppasswords
#      (selecione "Outro" e dê um nome como "BloxAI")
#   3. Use os valores abaixo:
#      SMTP_HOST=smtp.gmail.com
#      SMTP_PORT=587
#      SMTP_USER=seu_email@gmail.com
#      SMTP_PASS=a_senha_de_app_gerada (16 chars, sem espaços)
#
# ► Outlook / Hotmail (grátis, 300/dia)
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_USER=seu_email@outlook.com
#   SMTP_PASS=sua_senha
#
# ► Brevo (grátis, 300/dia — não exige domínio)
#   1. Crie conta em https://www.brevo.com
#   2. Transactional → SMTP & API → copie as credenciais
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=seu_login_brevo
#   SMTP_PASS=chave_smtp_da_brevo

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=idebloxai@gmail.com
SMTP_PASS=ycss limd tpxa qlwy

# Endereço remetente (deve ser o mesmo do SMTP_USER ou um alias autorizado).
EMAIL_FROM=idebloxai@gmail.com


# -----------------------------------------------------------------------------
# MODELOS DE IA — pelo menos UMA chave é obrigatória
# -----------------------------------------------------------------------------

# DeepSeek V3 — recomendado (custo ~20x menor que GPT-4, qualidade próxima)
# Como obter:
#   1. Crie conta em https://platform.deepseek.com
#   2. API Keys → Create API Key
#   3. Deposite créditos (mínimo $5 USD, dura muito tempo)
DEEPSEEK_API_KEY=

# OpenAI — modelo secundário (GPT-5.4 Mini)
# Como obter:
#   1. Crie conta em https://platform.openai.com
#   2. API Keys → Create new secret key
#   3. Adicione créditos em Billing → Add to credit balance
OPENAI_API_KEY=

# Anthropic — modelo de review (Claude 3.5 Sonnet)
# Como obter:
#   1. Crie conta em https://console.anthropic.com
#   2. API Keys → Create Key
#   3. Adicione créditos em Plans & Billing
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# BILLING / PRECIFICAÇÃO
# -----------------------------------------------------------------------------

# Margem de lucro padrão da plataforma em % (0 a 99).
# Fórmula aplicada: valor_cobrado = custo_real / (1 - MARGEM/100)
# Exemplos:
#   50 → cobra 2× o custo real (margem de 50%)
#   30 → cobra ~1.43× o custo real (margem de 30%)
# Pode ser sobrescrito por usuário no painel admin.
PROFIT_MARGIN_PERCENT=50

# Saldo inicial em USD concedido a cada nova conta (crédito de boas-vindas).
# Use 0 para não dar bônus, ou ex: 0.50 para dar 50 centavos de teste.
SIGNUP_BONUS_BALANCE_USD=0.5
