# =============================================================================
#  BLOX AI — Frontend (Vite + React)  |  Variáveis de Ambiente
#  Copie este arquivo: cp .env.example .env
#  Variáveis de frontend DEVEM começar com VITE_ para ficarem acessíveis
#  no código via import.meta.env.VITE_NOME_DA_VARIAVEL
#  Nunca coloque segredos aqui — este arquivo vai para o bundle público.
# =============================================================================


# -----------------------------------------------------------------------------
# BACKEND
# -----------------------------------------------------------------------------

# URL base do backend. O frontend usa isso para todas as chamadas de API
# e para redirecionar o usuário ao fluxo OAuth da Roblox.
#
# ► Desenvolvimento local
#   Deve bater com PORT do backend (.env do backend)
VITE_BACKEND_URL=http://localhost:5000

# ► Produção
#   Troque pelo domínio real do seu servidor/VPS/Railway/Render etc.
# VITE_BACKEND_URL=https://api.seudominio.com
